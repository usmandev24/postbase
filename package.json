{
  "name": "postbase",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "dotenvx run --env-file=.env.production -- cross-env DEBUG=posts:* node ./dist/app.mjs",
    "dev": "dotenvx run --env-file=.env.development -- cross-env DEBUG=posts:* tsx ./src/app.mjs",
    "watch": "tailwindcss -i ./src/public/assets/stylesheets/input.css -o ./src/public/assets/stylesheets/styles.css --watch --minify",
    "prisma": "dotenvx run --env-file=.env.development -- prisma --config=./src/prisma.config.ts",
    "init-catg": "dotenvx run --env-file=.env.development -- tsx ./src/models/init-categories.mjs",
    "init-pics": "dotenvx run --env-file=.env.development -- tsx ./src/models/set-prisma-pics.mjs",
    "build": "pnpm run pris-dbpull-pro; pnpm run pris-gen-pro; tsc; pnpm run copy-assets;  pnpm run init-catg-pro",
    "copy-assets": "cp -r src/public/assets dist/public; cp -r src/views dist/; cp -r src/partials dist/",
    "pris-dbpull-pro": "dotenvx run --env-file=.env.production -- prisma db push --config=./src/prisma.config.ts",
    "pris-gen-pro": "dotenvx run --env-file=.env.production -- prisma generate --config=./src/prisma.config.ts",
    "init-catg-pro": "dotenvx run --env-file=.env.production -- node ./dist/models/init-categories.mjs ",
    "init-pics-pro": "dotenvx run --env-file=.env.production -- node ./dist/models/set-prisma-pics.mjs"
  },
  "author": "Usman Ghani",
  "license": "",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.55.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "feather-icons": "^4.29.2",
    "hbs": "^4.2.0",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "keyv": "^5.6.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "quick-lru": "^7.3.0",
    "rotating-file-stream": "^3.2.9",
    "sanitize-html": "^2.17.1",
    "serve-favicon": "^2.5.1",
    "superagent": "^10.3.0",
    "trix": "^2.1.17",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.11.0",
    "@types/pg": "^8.18.0",
    "@types/sanitize-html": "^2.16.1",
    "daisyui": "^5.5.19",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
