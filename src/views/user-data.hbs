<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User_Report_{{user.username}}</title>
    <base href="{{baseUrl}}/"> 
    <style>
        :root {
            --text-color: #1a1a1a;
            --muted-color: #666666;
            --border-color: #eeeeee;
            --accent-green: #2e7d32;
            --page-bg: #ffffff;
            --bg-color: #f4f7f6;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 40px 15px;
            line-height: 1.5;
        }

        .page {
            max-width: 850px;
            margin: 0 auto;
            background: var(--page-bg);
            padding: 40px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            border-radius: 8px;
        }

        /* Header Layout */
        .report-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 3px solid var(--accent-green);
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .profile-info h1 { margin: 0; color: var(--accent-green); font-size: 1.8rem; }
        .user-photo {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: #eee;
            object-fit: cover;
            border: 2px solid var(--border-color);
        }

        /* Typography & Components */
        .section-title {
            text-transform: uppercase;
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--muted-color);
            margin-top: 40px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 5px;
            letter-spacing: 1px;
        }

        .record {
            padding: 15px 0;
            border-bottom: 1px solid #f9f9f9;
        }

        .record-title {
            font-weight: 600;
            font-size: 1.1rem;
            color: var(--accent-green);
            text-decoration: none;
        }

        .metadata {
            font-size: 0.8rem;
            color: #888;
            margin: 4px 0 10px 0;
        }

        .post-content {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .cover-thumb {
            width: 120px;
            height: 80px;
            object-fit: cover;
            border-radius: 4px;
            background: #eee;
        }

        .body-text {
            font-size: 0.95rem;
            min-width: 50vw;
            
        }

        .badge {
            font-size: 0.7rem;
            padding: 2px 6px;
            border-radius: 4px;
            background: #eee;
            font-weight: bold;
        }

        .label { font-weight: 600; color: #444; }

        @media print {
            body { background: none; padding: 0; }
            .page { box-shadow: none; width: 100%; border: none; }
        }
    </style>
</head>
<body>

{{#if user}}
    <div class="page">
        <div class="report-header">
            <div class="profile-info">
                <h1>{{user.displayName}}</h1>
                <p><strong>@{{user.username}}</strong> | {{user.email}}</p>
                <p class="metadata">Account ID: {{user.id}} | Provider: {{user.provider}}</p>
            </div>
            {{#if user.photoURL}}
                <img src="{{user.photoURL}}" alt="Profile" class="user-photo">
            {{/if}}
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <div>
                <span class="label">Bio/About:</span>
                <p style="font-size: 0.9rem;">{{#if user.about}}{{user.about}}{{else}}No bio provided.{{/if}}</p>
            </div>
            <div>
                <span class="label">Feed Categories:</span>
                <p style="font-size: 0.9rem;">{{#if user.feedCatgs}}
                    {{#each user.feedCatgs}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}
                    {{else}}General{{/if}}</p>
            </div>
        </div>

        <h2 class="section-title">Authored Posts ({{user.posts.length}})</h2>
        {{#each user.posts}}
            <div class="record">
                <div class="record-title">
                    {{#if title}}{{title}}{{else}}Untitled Post{{/if}}
                    <span class="badge">{{#if public}}Public{{else}}Private{{/if}}</span>
                </div>
                <div class="metadata">
                    Created: {{createdAt}} | Key: {{key}}
                </div>
                <div class="post-content">
                    {{#if coverPic}}
                        <img src="{{coverPic}}" class="cover-thumb" alt="Cover">
                    {{/if}}
                    <div class="body-text">{{{body}}}</div>
                </div>
            </div>
        {{else}}
            <p class="metadata">This user hasn't published any posts yet.</p>
        {{/each}}

        <h2 class="section-title">Recent Comments ({{user.comments.length}})</h2>
        {{#each user.comments}}
            <div class="record">
                <div class="metadata">
                    On Post: <strong>{{postkey}}</strong> | Date: {{createdAt}}
                </div>
                <div class="body-text" style="color: #333; border-left: 3px solid #eee; padding-left: 10px;">{{{body}}}</div>
            </div>
        {{else}}
            <p class="metadata">No comment history recorded.</p>
        {{/each}}

        <h2 class="section-title">Liked Content ({{user.likes.length}})</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 15px;">
            {{#each user.likes}}
                <div class="record">
                <div class="record-title"  style="color: #00e632;">
                    {{#if title}}{{title}}{{else}}Untitled Post{{/if}}
                    
                </div>
                <div class="metadata">
                    Created: {{createdAt}} | Key: {{key}}
                </div>
                <div class="post-content">
                    {{#if coverPic}}
                        <img src="{{coverPic}}" class="cover-thumb" alt="Cover">
                    {{/if}}
                    <div class="body-text">{{{body}}}</div>
                </div>
            </div>
            {{else}}
                <p class="metadata">No likes recorded.</p>
            {{/each}}
        </div>

        <div style="margin-top: 60px; text-align: center; font-size: 0.75rem; color: #bbb; border-top: 1px solid #f0f0f0; padding-top: 20px;">
            Report generated for {{user.username}} | System Date: {{date}}
            {{#if user.photo_updatedAt}}<br>Profile Last Updated: {{user.photo_updatedAt}}{{/if}}
        </div>
    </div>
{{else}}
    <div class="page" style="text-align: center; padding: 100px 0;">
        <h1 style="color: #cc0000;">User Not Found</h1>
        <p>The requested user object is null or undefined.</p>
    </div>
{{/if}}

</body>
</html>