<div class="max-w-4xl mx-auto p-6 md:p-12">

  <header class="flex flex-col items-center text-center mb-6">
    <div class="relative mb-6">
      <div class="avatar">
        <div class="w-32 h-32  rounded-4xl ring ring-primary ring-offset-base-100 ring-offset-4 shadow-2xl">
          <img src="{{publicUser.photoURL}}" alt="{{publicUser.username}}" />
        </div>
      </div>
      <div
        class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 bg-primary/10 blur-3xl rounded-full">
      </div>
    </div>

    <h1 class="text-4xl md:text-5xl font-black tracking-tighter mb-4 text-base-content">
      {{publicUser.displayName}}
    </h1>

    <div class="flex flex-wrap justify-center gap-3 mb-6">
      <span class="badge badge-lg bg-base-200 border-none font-black text-[11px] uppercase tracking-widest px-4 py-4">
        @{{publicUser.username}}
      </span>
      <span
        class="badge badge-lg bg-primary/10 text-primary border-none font-black text-[11px] uppercase tracking-widest px-4 py-4">
        {{postlist.length}} Posts
      </span>
    </div>

    <p class="max-w-2xl text-lg md:text-xl text-base-content/70 leading-relaxed font-medium">
      {{publicUser.about}}
    </p>
  </header>

  <div class="divider opacity-50 mb-10"></div>

  <section class="space-y-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-black tracking-tight uppercase  text-base-content/30">Recent Work</h2>
      <div class="h-px flex-1 bg-base-200 ml-6"></div>
    </div>

    {{#if postlist}}
    <div id="postlist" class="flex flex-col gap-8">
      {{#each postlist}}
      <div id="{{key}}"
        class="card bg-base-200/60 dark:bg-base-200/50 border border-base-200 shadow-sm hover:border-base-300 transition-colors mb-2">

        <div class="card-body  p-4 sm:p-7">

          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center gap-3">
              <div class="avatar">
                <div class="w-11 h-11 rounded-xl bg-base-200">
                  <img src="{{auther.photoURL}}" alt="{{auther.username}}">
                </div>
              </div>
              <div class="flex flex-col">
                <a href="/users/profile/{{auther.username}}"
                  class="font-black text-base tracking-tight hover:underline transition-all">
                  {{auther.username}}
                </a>
                <div class="flex items-center gap-2 mt-0.5">
                  <span data-time="{{createdAt}}"
                    class="updatedAt text-[11px] font-bold opacity-70 uppercase tracking-widest"></span>
                  <span class="w-1 h-1 rounded-full bg-base-300"></span>
                  <div class=" hidden sm:flex gap-2 flex-wrap">
                    {{#each catgs}}
                    <a href="/explore/{{catgName}}"
                      class="text-[10px] font-black uppercase text-primary/90 tracking-wide hover:underline">
                      #{{catgName}}
                    </a>
                    {{/each}}
                  </div>
                </div>
              </div>
            </div>

            <div id="{{key}}-info-container" class="flex flex-col items-end">
              <span id="{{key}}-info"
                class="badge badge-success badge-outline border-2 text-[10px] font-black uppercase px-2 py-3 hidden rounded-lg"></span>
            </div>
          </div>

          <div class="sm:hidden flex flex-wrap gap-2 mb-3">
            {{#each catgs}}
            <a href="/explore/{{catgName}}"
              class="text-[10px] font-black uppercase text-primary/90 tracking-wide hover:underline">
              #{{catgName}}
            </a>
            {{/each}}
          </div>

          <a id="{{key}}-link" href="/posts/view?key={{key}}" class="block mb-4 group cursor-pointer">
            <h2 id="{{key}}-title"
              class="text-xl md:text-2xl font-black tracking-tight leading-[1.2] mb-2 group-hover:text-primary transition-colors">
              {{title}}
            </h2>
            <div id="{{key}}-body" class="text-base-content/80 text-sm md:text-base line-clamp-3 leading-relaxed">
              {{{body}}}
            </div>
          </a>

          {{#if coverPic}}
          <a href="/posts/view?key={{key}}"
            class="block mb-4 aspect-16/8 overflow-hidden rounded-2xl border border-base-200 bg-base-200/30">
            <img src="{{coverPic}}" alt="{{title}}" class="w-full h-full object-cover rounded-2xl" />
          </a>
          {{/if}}

          <div class="flex items-center justify-between mt-2">
            <div class="flex items-center gap-1">
              <button data-postkey="{{key}}" class="like-btn btn btn-ghost btn-sm rounded-xl gap-2 text-success ">
                <span id="{{key}}-likeLogo" data-feather="thumbs-up" class="h-4 w-4"></span>
                <span id="{{key}}-likes" class="font-black text-xs">{{_count.likes}}</span>
              </button>

              <div class="btn btn-ghost btn-sm rounded-xl gap-2 text-info pointer-events-none opacity-80">
                <span data-feather="message-circle" class="h-4 w-4"></span>
                <span id="{{key}}-comments" class="font-black text-xs">{{_count.comments}}</span>
              </div>
            </div>

            <a href="/posts/view?key={{key}}"
              class="btn btn-ghost btn-sm rounded-xl px-4 text-xs font-black  tracking-widest hover:text-primary transition-colors">
              Read <span data-feather="arrow-right" class="h-5 w-9"></span>
            </a>
          </div>

        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="text-center py-20 bg-base-200/30 rounded-[3rem] border-2 border-dashed border-base-300">
      <p class="font-black opacity-20 uppercase tracking-[0.3em]">No public posts yet</p>
    </div>
    {{/if}}
  </section>
</div>
<script src="/assets/javascripts/relative-time.js"></script>

{{#if user }}
<script src="/assets/javascripts/like-control.js"></script>
{{/if }}